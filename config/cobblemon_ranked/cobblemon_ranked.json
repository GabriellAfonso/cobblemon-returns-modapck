{
	// Default language: zh or en
	"defaultLang": "en",
	// Default battle format: 'singles' / 默认的战斗模式'singles'（单打）
	"defaultFormat": "singles",
	// Minimum number of Pokémon allowed in a team / 宝可梦限制最少数量
	"minTeamSize": 1,
	// Maximum number of Pokémon allowed in a team / 宝可梦限制最多数量
	"maxTeamSize": 6,
	// Allow duplicate held items in a team / 是否允许队伍中携带重复道具 (道具条款)
	"allowDuplicateItems": true,
	// Enable Team Preview and Selection (Bring 6 Pick 3/4) / 是否启用队伍预览和选出阶段 (6选3/4)
	"enableTeamPreview": false,
	// Time allowed for team selection in seconds / 队伍选择阶段的时间限制(秒)
	"teamSelectionTime": 90,
	// Time allowed to choose an action each turn in seconds (0 = disabled) / 每回合选择行动的时间限制（秒，0为关闭）
	"turnActionTimeoutSeconds": 90,
	// Number of Pokemon to select for Singles (usually 3) / 单打模式选出的宝可梦数量 (通常为3)
	"singlesPickCount": 3,
	// Number of Pokemon to select for Doubles (usually 4) / 双打模式选出的宝可梦数量 (通常为4)
	"doublesPickCount": 4,
	// Maximum allowed Elo difference in matchmaking / 队伍Elo差限制
	"maxEloDiff": 200,
	// Max wait time for matchmaking (seconds), Elo range linearly expands to max multiplier / 最大匹配等待时间（秒），Elo 差距将线性放宽，从1倍放宽至最大倍率（如3倍）
	"maxQueueTime": 300,
	// Max Elo multiplier for matchmaking range (linear expansion) / 最大 Elo 匹配放宽倍率（线性放宽）
	"maxEloMultiplier": 3.0,
	// Season duration in days / 每个赛季的持续时间（天）
	"seasonDuration": 30,
	// Initial Elo at the start of the season / 赛季初始Elo
	"initialElo": 1000,
	// K-factor in Elo calculation / Elo计算中的K因子
	"eloKFactor": 32,
	// Minimum possible Elo score / 最低Elo分数限制
	"minElo": 0,
	// Loser protection rate (0.0 to 1.0). Loser will lose at most (winner_gain * loserProtectionRate). 1.0 = no protection / 败者保护率，败者最多扣除胜者获得的Elo * loserProtectionRate。1.0 = 不启用保护
	"loserProtectionRate": 1.0,
	// Banned Pokémon / 禁止使用的宝可梦
	"bannedPokemon": [
		"Mewtwo",
		"Arceus"
	],
	// Restricted Pokémon list / 受限宝可梦列表
	"restrictedPokemon": [
		"Mew",
		"Celebi"
	],
	// Maximum number of restricted Pokémon allowed in a team / 受限宝可梦最大允许携带数量
	"maxRestrictedCount": 2,
	// Banned held items for Pokémon / 禁止宝可梦携带的道具
	"bannedHeldItems": [
		"cobblemon:leftovers"
	],
	// Banned items in player's inventory / 禁止玩家背包携带的物品
	"bannedCarriedItems": [
		"cobblemon:leftovers"
	],
	// Banned moves for Pokémon / 禁止宝可梦使用的技能
	"bannedMoves": [
		"leechseed"
	],
	// Banned personalities for Pokémon /  禁止宝可梦使用的性格
	"bannedNatures": [],
	// Banned abilities for Pokémon / 禁止宝可梦使用的特性
	"bannedAbilities": [],
	// Banned gender for Pokémon / 禁止宝可梦使用的性别
	"bannedGenders": [],
	// Banned shiny Pokémon from participating in battles / 是否禁止闪光宝可梦参战
	"bannedShiny": false,
	// Ban Pokémon with usage rate below this threshold (0 to disable, 0.1 = 10%) / 禁止使用率低于此阈值的宝可梦（0为关闭，0.1表示10%）
	"banUsageBelow": 0.0,
	// Ban Pokémon with usage rate above this threshold (0 to disable, 0.1 = 10%) / 禁止使用率高于此阈值的宝可梦（0为关闭，0.1表示10%）
	"banUsageAbove": 0.0,
	// Ban top N most used Pokémon (0 to disable) / 禁止使用排行前N的宝可梦（0为关闭）
	"banTopUsed": 0,
	// Only allow base form Pokémon that can evolve / 是否只允许使用能够进化的最初形态
	"onlyBaseFormWithEvolution": false,
	// Allowed battle formats: 'singles', 'doubles', '2v2singles' / 允许的战斗模式：'singles'（单打）, 'doubles'（双打）, '2v2singles'（2v2单打）
	"allowedFormats": [
		"singles",
		"doubles",
		"2v2singles"
	],
	// Max Pokémon level allowed (0 = no limit) / 允许的宝可梦等级，0 = 无限制
	"maxLevel": 0,
	// Allowed to have the same species of Pokémon in a single team / 允许同一个队伍中出现相同的宝可梦
	"allowDuplicateSpecies": false,
	// Enable forced modification of Pokémon levels / 是否启用强制修改宝可梦等级
	"enableCustomLevel": false,
	// Forcefully modify the level of Pokémon / 设置强制修改宝可梦的等级
	"customBattleLevel": 50,
	// Prevent players from breaking blocks during ranked battles / 对战时是否禁止玩家破坏方块
	"preventBlockBreaking": true,
	// Restore Pokémon HP after battle / 对战结束后是否恢复宝可梦血量
	"restorePokemonHpAfterBattle": true,
	// Available battle arenas after matchmaking, each with 2 teleport coordinates / 匹配成功后可用的战斗场地列表，支持多个场地随机挑选，每个场地需要定义 2 个传送坐标
	"battleArenas": [
		{
			"world": "minecraft:overworld",
			"playerPositions": [
				{
					"x": 0.0,
					"y": 70.0,
					"z": 0.0
				},
				{
					"x": 10.0,
					"y": 70.0,
					"z": 0.0
				}
			]
		},
		{
			"world": "minecraft:overworld",
			"playerPositions": [
				{
					"x": 100.0,
					"y": 65.0,
					"z": 100.0
				},
				{
					"x": 110.0,
					"y": 65.0,
					"z": 100.0
				}
			]
		}
	],
	// Victory rewards configuration (executed after each win) / 每场比赛获胜的奖励配置
	"victoryRewards": [
