	"rankRequirements": {
		"Bronze": 0.0,
		"Silver": 0.3,
		"Gold": 0.3,
		"Platinum": 0.3,
		"Diamond": 0.3,
		"Master": 0.3
	},
	// Enable cross-server matchmaking / 是否启用跨服匹配
	"enableCrossServer": false,
	// Cloud server ID for this server(Cannot be repeated with others) / 本服的云端标识(不可与他人重复)
	"cloudServerId": "",
	// Cloud server auth token(Leave blank for the public cloud server) / 云端验证用密钥(公开云服留空即可)
	"cloudToken": "",
	// Cloud API address(Either IP or domain name is acceptable) / 云端 API 地址(ip或者域名都可以)
	"cloudApiUrl": "",
	// Cloud WebSocket Address(Either IP or domain name is acceptable) / 云端 WebSocket 地址(ip或者域名都可以)
	"cloudWebSocketUrl": ""
