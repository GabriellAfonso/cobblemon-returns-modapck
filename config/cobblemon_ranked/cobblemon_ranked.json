	// Elo thresholds for rank titles (customizable) / 段位名称配置（可增减）
	"rankTitles": {
		"3500": "Master",
		"3000": "Diamond",
		"2500": "Platinum",
		"2000": "Gold",
		"1500": "Silver",
		"0": "Bronze"
